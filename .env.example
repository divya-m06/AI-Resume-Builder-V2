# ─────────────────────────────────────────────────────────────────────────────
#  AI Resume Builder — environment variables (reference only)
#
#  Copy the appropriate snippets into real files — NEVER commit secrets:
#    backend/.env     → Supabase, Groq, JWT, CORS
#    frontend/.env    → VITE_API_BASE_URL
#
#  See README.md for full setup.
# ─────────────────────────────────────────────────────────────────────────────

# --- Backend (backend/.env) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your_anon_key
# GROQ_API_KEY=gsk_...
# APP_SECRET_KEY=generate_with_python_secrets_token_hex_32
# FRONTEND_URL=http://localhost:5173
# Optional: multiple CORS origins (comma-separated), e.g.
# FRONTEND_URL=https://app.vercel.app,https://preview-xxx.vercel.app

# --- Frontend (frontend/.env) ---
# VITE_API_BASE_URL=http://localhost:8000
