# ─────────────────────────────────────────────────────────────────
#  AI Resume Builder — Backend Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────────

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Groq API — https://console.groq.com/keys (recommended; optional — app starts without it,
# but roadmaps, interview questions, ATS tips, and JD AI hints need a valid key)
GROQ_API_KEY=gsk_your_groq_api_key_here

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=your_64_char_hex_secret_here

# Frontend origin(s) allowed by CORS (comma-separated for prod + preview URLs).
# Local development:  http://localhost:5173
# Production:         https://your-app.vercel.app
# Multiple:           https://your-app.vercel.app,https://your-app-git-branch.vercel.app
FRONTEND_URL=http://localhost:5173
